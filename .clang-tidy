# clang-tidy configuration for tg-cli
# Enabled: bugprone-*, cert-*, clang-analyzer-*
# Disabled checks that produce excessive noise on idiomatic C11 code:
#   cert-err33-c  — requires checking return value of every printf/snprintf/etc.
#   clang-analyzer-security.insecureAPI.DeprecatedOrUnsafeBufferHandling
#                — flags standard memcpy/snprintf/fprintf as unsafe; we use
#                  bounded variants already
#   bugprone-easily-swappable-parameters — noisy for internal functions with
#                  positional int/size_t pairs
#   clang-analyzer-osx-*,clang-analyzer-optin.osx-*  — macOS-only checkers
#                  irrelevant to this project
Checks: >
  -*,
  bugprone-*,
  cert-*,
  clang-analyzer-*,
  -cert-err33-c,
  -bugprone-easily-swappable-parameters,
  -clang-analyzer-security.insecureAPI.DeprecatedOrUnsafeBufferHandling,
  -clang-analyzer-osx.*,
  -clang-analyzer-optin.osx.*,
  -clang-analyzer-optin.mpi.*,
  -clang-analyzer-optin.cplusplus.*,
  -clang-analyzer-cplusplus.*,
  -clang-analyzer-fuchsia.*,
  -clang-analyzer-apiModeling.google.*,
  -clang-analyzer-apiModeling.llvm.*

WarningsAsErrors: ""

HeaderFilterRegex: "^((?!vendor).)*$"

CheckOptions:
  - key: bugprone-implicit-widening-of-multiplication-result.UseCXXStaticCastsInCppSources
    value: false
